# CodIn Agent environment configuration

# Server
BHARAT_AGENT_PORT=43120
NODE_ENV=development
LOG_LEVEL=info

# Security
# Required when NODE_ENV=production
JWT_SECRET=replace-with-a-strong-random-secret

# Rate Limiting (token bucket per IP/user)
# Requests per minute per client
RATE_LIMIT_PER_MINUTE=60
# Requests per hour per client
RATE_LIMIT_PER_HOUR=1000

# Security Headers
# CORS origin pattern (can use wildcards: http://localhost:*)
CORS_ORIGIN=http://localhost:*
# Allow credentials in CORS requests
CORS_CREDENTIALS=true
# Content Security Policy
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
# Enable Strict-Transport-Security header
ENABLE_HSTS=true
# HSTS max age in seconds (default 1 year)
HSTS_MAX_AGE=31536000

# Runtime
CODIN_OFFLINE_MODE=false
