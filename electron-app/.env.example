# Environment variables for CodIn Electron App
# Copy this to .env for local development

# Development mode
NODE_ENV=development

# CodIn Agent configuration
CODIN_AGENT_PORT=43120
CODIN_AGENT_HOST=localhost

# Model download URLs (override defaults)
# QWEN_MODEL_URL=https://custom-url/qwen2.5-coder-1.5b.gguf
# DEEPSEEK_MODEL_URL=https://custom-url/deepseek-r1-7b.gguf

# AI4Bharat configuration
AI4BHARAT_API_KEY=
AI4BHARAT_BASE_URL=https://models.ai4bharat.org

# Logging
LOG_LEVEL=info

# GUI dev server (for development only)
GUI_DEV_SERVER=http://localhost:5173
